{
  "name": "@zennopay/react-native",
  "version": "0.2.1",
  "description": "Zennopay PaymentSheet for React Native — a thin native bridge over the native Zennopay iOS/Android checkout sheets (scan → amount → confirm → status). One call in, one PaymentResult out.",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/index.d.ts",
  "react-native": "src/index.ts",
  "source": "src/index.ts",
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "zennopay-react-native.podspec",
    "!**/__tests__",
    "!**/example"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "prepare": "tsc --noEmit"
  },
  "keywords": [
    "zennopay",
    "react-native",
    "ios",
    "android",
    "payments",
    "qr",
    "promptpay",
    "vietqr",
    "turbomodule"
  ],
  "homepage": "https://zennopay.in",
  "repository": {
    "type": "git",
    "url": "https://github.com/Zennopay/zennopay-react-native-sdk.git"
  },
  "license": "MIT",
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-native": ">=0.70.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "react": "18.2.0",
    "react-native": "0.74.0",
    "typescript": "^5.4.0"
  },
  "codegenConfig": {
    "name": "ZennopayReactNativeSpec",
    "type": "modules",
    "jsSrcsDir": "src",
    "android": {
      "javaPackageName": "com.zennopay.reactnative"
    }
  }
}
